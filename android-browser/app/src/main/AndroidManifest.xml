<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.DOWNLOAD_WITHOUT_NOTIFICATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".VeloApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VeloBrowser"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- ===== MAIN PROCESS ACTIVITIES ===== -->

        <activity
            android:name=".ui.browser.BrowserActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.browser.BrowserActivity"
            android:label="@string/settings" />

        <activity
            android:name=".ui.profiles.ProfileManagerActivity"
            android:exported="false"
            android:parentActivityName=".ui.browser.BrowserActivity"
            android:label="@string/profiles" />

        <activity
            android:name=".ui.downloads.DownloadsActivity"
            android:exported="false"
            android:parentActivityName=".ui.browser.BrowserActivity"
            android:label="@string/downloads" />

        <!-- ===== ISOLATED TAB PROCESSES ===== -->
        <!-- Each runs in its own Android process with separate cookies, storage & cache -->

        <activity
            android:name=".ui.isolated.IsolatedSlot1Activity"
            android:exported="false"
            android:process=":isolated1"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:taskAffinity="${applicationId}.isolated1"
            android:label="@string/isolated_tab_label" />

        <activity
            android:name=".ui.isolated.IsolatedSlot2Activity"
            android:exported="false"
            android:process=":isolated2"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:taskAffinity="${applicationId}.isolated2"
            android:label="@string/isolated_tab_label" />

        <activity
            android:name=".ui.isolated.IsolatedSlot3Activity"
            android:exported="false"
            android:process=":isolated3"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:taskAffinity="${applicationId}.isolated3"
            android:label="@string/isolated_tab_label" />

        <activity
            android:name=".ui.isolated.IsolatedSlot4Activity"
            android:exported="false"
            android:process=":isolated4"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:taskAffinity="${applicationId}.isolated4"
            android:label="@string/isolated_tab_label" />

        <!-- ===== KEEP-ALIVE FOREGROUND SERVICES (one per isolated process) ===== -->

        <service
            android:name=".service.TabKeepAliveService1"
            android:exported="false"
            android:process=":isolated1"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".service.TabKeepAliveService2"
            android:exported="false"
            android:process=":isolated2"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".service.TabKeepAliveService3"
            android:exported="false"
            android:process=":isolated3"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".service.TabKeepAliveService4"
            android:exported="false"
            android:process=":isolated4"
            android:foregroundServiceType="dataSync" />

        <!-- ===== FILE PROVIDER ===== -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
