<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/color_toolbar">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- ViewPager row: prev < | pager | next > -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="76dp">

        <ImageButton
            android:id="@+id/btnMenuPrev"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/color_icon_secondary"
            android:contentDescription="@string/back"
            android:scaleType="centerInside" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/menuViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/btnMenuPrev"
            android:layout_toStartOf="@id/btnMenuNext" />

        <ImageButton
            android:id="@+id/btnMenuNext"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_forward"
            android:tint="@color/color_icon_secondary"
            android:contentDescription="@string/forward"
            android:scaleType="centerInside" />

    </RelativeLayout>

    <!-- Page indicator dots -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/dot1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_menu_dot"
            android:alpha="1.0" />

        <View
            android:id="@+id/dot2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_menu_dot"
            android:alpha="0.3" />

        <View
            android:id="@+id/dot3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_menu_dot"
            android:alpha="0.3" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Bottom row: power (close app) + dismiss -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnExit"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_power"
            android:tint="@color/color_icon_secondary"
            android:contentDescription="@string/menu_exit" />

        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="1dp" />

        <ImageButton
            android:id="@+id/btnDismissMenu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_down"
            android:tint="@color/color_icon_secondary"
            android:contentDescription="@string/cancel" />

    </LinearLayout>

</LinearLayout>
