<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VeloBrowser" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_variant</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="colorError">@color/color_error</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:statusBarColor">@color/color_toolbar</item>
        <item name="android:navigationBarColor">@color/color_toolbar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.VeloBrowser.Incognito" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#7C4DFF</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:statusBarColor">#1A1A2E</item>
        <item name="android:navigationBarColor">#1A1A2E</item>
    </style>
</resources>
