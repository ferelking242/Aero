<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C1E"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Night Mode -->
        <LinearLayout
            android:id="@+id/menuNightMode"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconNightMode"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_night_mode"
                android:tint="#1A73E8"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/night_mode"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Bookmarks -->
        <LinearLayout
            android:id="@+id/menuBookmarks"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_bookmark"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bookmarks"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- History -->
        <LinearLayout
            android:id="@+id/menuHistory"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_refresh"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/history"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Downloads -->
        <LinearLayout
            android:id="@+id/menuDownloads"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_download"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/downloads"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Incognito -->
        <LinearLayout
            android:id="@+id/menuIncognito"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_incognito"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/incognito_mode"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Share -->
        <LinearLayout
            android:id="@+id/menuShare"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_share"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/share"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Add Bookmark -->
        <LinearLayout
            android:id="@+id/menuAddBookmark"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconAddBookmark"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_bookmark"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_bookmark"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Desktop Mode -->
        <LinearLayout
            android:id="@+id/menuDesktopMode"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/iconDesktopMode"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_desktop"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/desktop_mode"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Profiles / Tools -->
        <LinearLayout
            android:id="@+id/menuProfiles"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_edit"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profiles"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/menuSettings"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_more_vert"
                android:tint="#FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:maxLines="2" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom row: New tab + Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/menuNewTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/new_tab"
            android:textColor="#1A73E8"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#333333"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/menuNewIncognito"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/new_incognito_tab"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

</LinearLayout>
